{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/page.jsx",
    "app/layout.jsx",
    "next.config.ts",
    "app/dashboard/page.jsx",
    "components/footer/team-card.jsx",
    "components/admin/section-cards.jsx",
    "lib/attendance.ts",
    "components/app-sidebar.jsx",
    "lib/removeTeamMember.js",
    "proxy.js",
    "components/nav-user-admin.jsx"
, "lib/resetAttendanceSummaryIfNeeded.js", "functions/src/index.js", "app/context/TeamsContext.js", "app/api/auth/session/route.js"  ],
  "exclude": ["node_modules"]
}
